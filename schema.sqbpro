-- CENTENARYO Database Schema
-- For: Senior Citizens Affairs System
-- =====================================================

-- 1. USERS (for authentication and audit logs)
CREATE TABLE users (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    username TEXT UNIQUE NOT NULL,
    password_hash TEXT NOT NULL,   -- store hashed passwords, not plain text
    full_name TEXT NOT NULL,
    role TEXT NOT NULL CHECK(role IN ('admin', 'encoder', 'auditor', 'viewer')),
    is_active INTEGER DEFAULT 1,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    last_login TIMESTAMP
);

-- 2. SENIOR CITIZENS (master registry)
CREATE TABLE senior_citizens (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    unique_identifier TEXT UNIQUE NOT NULL,   -- e.g., OSCA-2026-0001
    first_name TEXT NOT NULL,
    middle_name TEXT,
    last_name TEXT NOT NULL,
    suffix TEXT,                               -- Jr., Sr., III
    birth_date DATE NOT NULL,
    age INTEGER,                               -- can be computed, but stored for performance
    sex TEXT CHECK(sex IN ('M', 'F')),
    address TEXT NOT NULL,
    barangay TEXT,
    city_municipality TEXT,
    contact_number TEXT,
    is_indigent INTEGER DEFAULT 0,             -- 0 = no, 1 = yes
    vital_status TEXT DEFAULT 'alive' CHECK(vital_status IN ('alive', 'deceased')),
    date_of_death DATE,
    is_active INTEGER DEFAULT 1,               -- soft delete flag
    registration_date DATE DEFAULT CURRENT_DATE,
    last_updated TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    notes TEXT
);

-- 3. PENSION DISBURSEMENTS (payroll records)
CREATE TABLE pension_disbursements (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    senior_id INTEGER NOT NULL,
    quarter INTEGER NOT NULL CHECK(quarter BETWEEN 1 AND 4),
    year INTEGER NOT NULL,
    amount REAL NOT NULL,
    disbursement_date DATE NOT NULL,
    status TEXT DEFAULT 'pending' CHECK(status IN ('pending', 'released', 'cancelled')),
    released_by INTEGER,                       -- user_id who released
    release_notes TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (senior_id) REFERENCES senior_citizens(id) ON DELETE CASCADE,
    FOREIGN KEY (released_by) REFERENCES users(id)
);

-- 4. DISCOUNT BOOKLETS (inventory tracking)
CREATE TABLE discount_booklets (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    serial_number TEXT UNIQUE NOT NULL,
    senior_id INTEGER NOT NULL,
    issue_date DATE NOT NULL,
    expiry_date DATE,
    replacements_count INTEGER DEFAULT 0,
    last_replacement_date DATE,
    is_active INTEGER DEFAULT 1,
    notes TEXT,
    FOREIGN KEY (senior_id) REFERENCES senior_citizens(id) ON DELETE CASCADE
);

-- 5. SENIOR IDs (QR-coded identification cards)
CREATE TABLE senior_ids (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    senior_id INTEGER NOT NULL UNIQUE,          -- one active ID per senior at a time
    qr_code TEXT UNIQUE NOT NULL,               -- stored QR code data (or filename)
    issue_date DATE NOT NULL,
    expiry_date DATE,
    printed_by INTEGER,                         -- user_id who printed
    is_active INTEGER DEFAULT 1,
    replacement_reason TEXT,
    FOREIGN KEY (senior_id) REFERENCES senior_citizens(id) ON DELETE CASCADE,
    FOREIGN KEY (printed_by) REFERENCES users(id)
);

-- 6. ANOMALY FLAGS (AI-detected or manually flagged)
CREATE TABLE anomaly_flags (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    senior_id INTEGER NOT NULL,
    flag_reason TEXT NOT NULL,                  -- e.g., &quot;duplicate record&quot;, &quot;suspicious claim pattern&quot;, &quot;deceased but active&quot;
    risk_score REAL,                            -- from Random Forest (0 to 1)
    detected_by TEXT,                           -- 'AI' or 'user'
    detection_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    reviewed_by INTEGER,                        -- user_id who reviewed
    review_date TIMESTAMP,
    resolution TEXT CHECK(resolution IN ('verified_clean', 'confirmed_fraud', 'pending')),
    resolution_notes TEXT,
    FOREIGN KEY (senior_id) REFERENCES senior_citizens(id) ON DELETE CASCADE,
    FOREIGN KEY (reviewed_by) REFERENCES users(id)
);

-- 7. AUDIT LOGS (for every transaction)
CREATE TABLE audit_logs (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id INTEGER NOT NULL,
    action TEXT NOT NULL,                       -- e.g., 'CREATE', 'UPDATE', 'DELETE', 'LOGIN', 'PAYROLL_GENERATE'
    table_name TEXT,                            -- affected table (e.g., 'senior_citizens')
    record_id INTEGER,                          -- primary key of affected record
    old_values TEXT,                            -- JSON or text dump
    new_values TEXT,
    ip_address TEXT,
    timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (user_id) REFERENCES users(id)
);

-- 8. SYSTEM SETTINGS (key-value store for configuration)
CREATE TABLE system_settings (
    key TEXT PRIMARY KEY,
    value TEXT,
    description TEXT,
    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    updated_by INTEGER,
    FOREIGN KEY (updated_by) REFERENCES users(id)
);

-- =====================================================
-- INDEXES for performance
-- =====================================================

CREATE INDEX idx_senior_name ON senior_citizens(last_name, first_name);
CREATE INDEX idx_senior_birthdate ON senior_citizens(birth_date);
CREATE INDEX idx_senior_barangay ON senior_citizens(barangay);
CREATE INDEX idx_senior_vital_status ON senior_citizens(vital_status);
CREATE INDEX idx_senior_identifier ON senior_citizens(unique_identifier);

CREATE INDEX idx_disbursement_senior ON pension_disbursements(senior_id);
CREATE INDEX idx_disbursement_date ON pension_disbursements(disbursement_date);
CREATE INDEX idx_disbursement_status ON pension_disbursements(status);

CREATE INDEX idx_booklet_serial ON discount_booklets(serial_number);
CREATE INDEX idx_booklet_senior ON discount_booklets(senior_id);

CREATE INDEX idx_anomaly_senior ON anomaly_flags(senior_id);
CREATE INDEX idx_anomaly_resolution ON anomaly_flags(resolution);
CREATE INDEX idx_anomaly_risk ON anomaly_flags(risk_score);

CREATE INDEX idx_audit_user ON audit_logs(user_id);
CREATE INDEX idx_audit_timestamp ON audit_logs(timestamp);
CREATE INDEX idx_audit_action ON audit_logs(action);

-- =====================================================
-- INSERT DEFAULT DATA (optional but helpful)
-- =====================================================

-- Default admin user (password = 'admin123' - you should hash this)
-- In practice, use a hashed password. This is just a placeholder.
INSERT INTO users (username, password_hash, full_name, role) 
VALUES ('admin', 'dummy_hash_replace_me', 'System Administrator', 'admin');

-- Default system settings
INSERT INTO system_settings (key, value, description) VALUES 
('pension_amount', '500.00', 'Default monthly pension amount per senior'),
('current_quarter', '1', 'Current quarter for payroll generation'),
('current_year', '2026', 'Current year'),
('auto_anomaly_detection', 'true', 'Enable automatic AI anomaly scanning');</sql><current_tab id="0"/></tab_sql></sqlb_project>
